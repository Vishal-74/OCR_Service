# Required — Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Required — OpenAI (GPT-4o + Whisper)
OPENAI_API_KEY=your-openai-api-key-here

# Optional — inventory after user confirms (reply 1)
# POST JSON: { "event": "order_confirmed", "sender": "whatsapp:...", "items": [...] }
INVENTORY_WEBHOOK_URL=

# Optional — WhatsApp your ops/stock number with the same summary
INVENTORY_NOTIFY_WHATSAPP=

# Local only (Railway sets PORT). On macOS, 5000 is often taken by AirPlay Receiver — use 5001 or 8000.
# PORT=5001
